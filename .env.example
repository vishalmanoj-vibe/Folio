# Portfolio Dashboard Environment Variables
# Copy this file to .env and fill in the values

# Database Path
DB_PATH=data/portfolio.db

# UI Refresh Intervals (milliseconds)
REFRESH_INTERVAL_MS=300000

# Market Configuration
MARKET_TIMEZONE=Australia/Sydney

# API Resiliency
API_MAX_RETRIES=3
API_RETRY_BACKOFF_BASE=2.0

# Caching (Seconds)
TECHNICALS_CACHE_TTL=86400
DIVIDENDS_CACHE_TTL=604800

# Alerts (Percentages as whole numbers, e.g., -20 for -20%)
ALERT_INDIVIDUAL_DRAWDOWN_PCT=-20.0
ALERT_PORTFOLIO_DRAWDOWN_PCT=-15.0

# Logging
LOG_LEVEL=INFO

# AI Analyst (Required)
GEMINI_API_KEY=your_api_key_here
