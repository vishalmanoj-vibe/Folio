# Portfolio Dashboard - Environment Configuration Example
# Copy this to .env and modify as needed

# CSV Configuration
PORTFOLIO_CSV=./data/raw/stock_portfolio_transactions.csv

# Refresh Configuration (milliseconds)
REFRESH_INTERVAL_MS=60000

# API Retry Configuration
API_MAX_RETRIES=3
API_RETRY_BACKOFF_BASE=2.0

# Cache Configuration (seconds)
CACHE_TTL_SECONDS=60

# Market Configuration
MARKET_TIMEZONE=Australia/Sydney

# Alert Thresholds (percentage)
ALERT_INDIVIDUAL_DRAWDOWN_PCT=-20.0
ALERT_PORTFOLIO_DRAWDOWN_PCT=-15.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=portfolio.log
LOG_FILE_ENABLED=true
